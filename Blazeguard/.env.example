# =========================
# App
# =========================
APP_ENV=development
EVENT_VERSION=v1

# =========================
# Kafka
# =========================
KAFKA_BROKER=localhost:9092
KAFKA_DLQ_TOPIC=events_dlq

# =========================
# API Gateway / Frontend
# =========================
PORT=8080
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080
VITE_AUTH_BASE_URL=http://localhost:2000
VITE_ORCHESTRATOR_URL=http://localhost:8090

# =========================
# Orchestrator
# =========================
ORCHESTRATOR_PORT=8090
ORCHESTRATOR_GRPC_PORT=9090
DETECTION_AGENT_URL=http://localhost:8001
PREDICTION_AGENT_URL=http://localhost:8002
LOGISTICS_AGENT_URL=http://localhost:8003
CITIZEN_ALERT_AGENT_URL=http://localhost:8004
SELF_AGENT_URL=http://localhost:8005

# =========================
# Logistics / External APIs
# =========================
MAPBOX_API_KEY=REPLACE_ME
MAPBOX_BASE_URL=https://api.mapbox.com
WEATHER_API_KEY=REPLACE_ME
WEATHER_API_BASE_URL=https://api.openweathermap.org
NASA_FIRMS_API_KEY=REPLACE_ME

# =========================
# PostgreSQL / PostGIS
# For Docker network: DB_HOST=postgres
# For host-run services: DB_HOST=localhost
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=REPLACE_ME
DB_NAME=blazeguard
DB_SSLMODE=disable
DATABASE_URL=postgres://postgres:REPLACE_ME@localhost:5432/blazeguard?sslmode=disable

# =========================
# Redis
# For Docker network: REDIS_HOST=redis
# For host-run services: REDIS_HOST=localhost
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# =========================
# Redis Cloud (future/deploy)
# =========================
# REDIS_URL=rediss://default:REPLACE_ME@your-redis-host:6380
# REDIS_PASSWORD=REPLACE_ME

# =========================
# Oracle AI Database 26ai (AI Agent Memory)
# =========================
ORACLE_AI_DB_DSN=REPLACE_ME
ORACLE_AI_DB_USER=REPLACE_ME
ORACLE_AI_DB_PASSWORD=REPLACE_ME
ORACLE_AI_DB_WALLET_PATH=
ORACLE_AI_DB_WALLET_PASSWORD=

# =========================
# ML Model
# =========================
ML_MODEL_HOST=0.0.0.0
ML_MODEL_PORT=9000
ML_MODEL_URL=http://localhost:9000
ML_MODEL_NAME=blazeguard-fire-model
MODEL_PATH=./models/fire_model.pt
ML_MODEL_API_KEY=REPLACE_ME

# =========================
# Reliability
# =========================
REQUEST_TIMEOUT_SECONDS=10
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=300